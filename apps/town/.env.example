# town server 配置文件模板
# 复制为 .env 并填写真实值(注意:不要把 .env 提交到 git)

# === MiniMax M3 LLM 配置 ===
# 必填:从 ~/.claude/secrets.json 的 minimax_coding_plan.api_key 读取
MINIMAX_API_KEY=sk-cp-your-key-here
# 可选:OpenAI 兼容端点
MINIMAX_BASE_URL=https://api.minimax.chat/v1
# 可选:模型名
MINIMAX_MODEL=MiniMax-M3
# 可选:日预算(单位 CNY),默认 20
LLM_DAILY_BUDGET_CNY=20

# === 基础设施 ===
# Redis 连接串(本机 docker 端口 6380)
REDIS_URL=redis://localhost:6380/0
# Postgres 异步连接串(本机 docker 端口 5433)
DATABASE_URL=postgresql+asyncpg://town:town_dev_pwd@localhost:5433/town
